diff --git a/defenvs/airopi_ax3.env b/defenvs/airopi_ax3.env
new file mode 100644
index 00000000000..ad88f8442ae
--- /dev/null
+++ b/defenvs/airopi_ax3.env
@@ -0,0 +1,41 @@
+baudrate=115200
+loadaddr=50000000
+ipaddr=192.168.1.1
+serverip=192.168.1.254
+ethaddr=aa:bb:cc:dd:ee:ff
+file_bl2=preloader.bin
+file_fip=bl31-uboot.fip
+file_firmware=firmware.itb
+file_initramfs=initramfs.bin
+bootargs=root=/dev/fit0 rootwait
+bootcmd=test x$bootdev = xmmc && run mmc_read_firmware && bootm $loadaddr$bootconf_mmc || run nor_read_firmware && bootm $loadaddr
+bootconf_mmc=#config-mt7981b_airopi_ax3#mt7981b_airopi_ax3-sd
+bootdev=nor
+bootmenu_0=[36m[1mRun default boot command[0m=run bootcmd ; run tftp_restore_system
+bootmenu_1=[36m[1mBoot System from Flash[0m=run bootcmd ; run confirm_return
+bootmenu_2=[32m[1mBoot System from TFTP[0m=run tftp_load_initramfs ; run confirm_return
+bootmenu_3=[32m[1mLoad System via TFTP then write to Flash[0m=run tftp_restore_system ; run confirm_return
+bootmenu_4=[33m[1mLoad BL2 via TFTP then write to Flash[0m=run tftp_update_bl2 ; run confirm_return
+bootmenu_5=[33m[1mLoad FIP via TFTP then write to Flash[0m=run tftp_update_fip ; run confirm_return
+bootmenu_6=[31m[1mSwitch boot device[0m=run switch_bootdev ; confirm_return
+bootmenu_7=[31m[1mReboot[0m=reset
+confirm_continue=askenv confirm [35m[1mContinue? [Y/n][0m 1 && flag=$confirm && setenv confirm ; test x$flag = xy || test x$flag = xY
+confirm_return=askenv - [35m[1mPress Enter to return to the boot menu![0m ; bootmenu 60
+mmc_read_firmware=run mmc_seek_fitaddr && mmc read $loadaddr $fitaddr 100 && imszb $loadaddr iosize && mmc read $loadaddr $fitaddr $iosize && setenv iosize
+mmc_seek_fitaddr=part start mmc 0 FIT voladdr && fitaddr=$voladdr && setenv voladdr
+mmc_write_firmware=run mmc_seek_fitaddr && imszb $loadaddr iosize && mmc erase $fitaddr $iosize && mmc write $loadaddr $fitaddr $iosize && setenv iosize
+nor_prep_erase=setexpr iosize $filesize + ffff && setexpr iosize $iosize / 10000 && setexpr iosize $iosize * 10000
+nor_read_firmware=mtd read firmware $loadaddr 0 10000 && imsz $loadaddr imgsize && mtd read firmware $loadaddr 0 $imgsize && setenv imgsize
+nor_verify_bl2=md5sum $loadaddr $filesize && echo [35m[1mThe MD5 must match the checksum above![0m && mtd read bl2 $loadaddr && md5sum $loadaddr $filesize
+nor_verify_fip=md5sum $loadaddr $filesize && echo [35m[1mThe MD5 must match the checksum above![0m && mtd read fip $loadaddr && md5sum $loadaddr $filesize
+nor_write_firmware=run nor_prep_erase && mtd erase firmware 0 $iosize && setenv iosize && mtd write firmware $loadaddr 0 $filesize
+setup_netconsole=setenv ncip $serverip && setenv stdin nc && setenv stdout nc && setenv stderr nc
+setup_ttlconsole=setenv stderr serial@11002000 && setenv stdout serial@11002000 && setenv stdin serial@11002000 && setenv ncip
+switch_console=if test x$stdin = xnc ; then run setup_ttlconsole && setenv bootdelay ; else run setup_netconsole && setenv bootdelay 60; fi
+switch_bootdev=if test x$bootdev = xmmc ; then setenv bootdev nor && echo [35m[1mNOR selected![0m ; else setenv bootdev mmc && echo [35m[1mMMC selected![0m ; fi && saveenv
+tftp_load_initramfs=tftpboot $loadaddr $file_initramfs && if test x$bootdev = xmmc ; then bootm $loadaddr$bootconf_mmc ; else bootm $loadaddr ; fi
+tftp_load_initramfs_loop=setenv cnt 0 ; while test $cnt -lt 20 ; do run tftp_load_initramfs ; setexpr cnt $cnt + 1 ; sleep 3 ; done ; setenv cnt
+tftp_restore_system=tftpboot $loadaddr $file_firmware && if test x$bootdev = xmmc ; then run mmc_write_firmware ; else run nor_write_firmware ; fi && run bootcmd
+tftp_restore_system_loop=setenv cnt 0 ; while test $cnt -lt 20 ; do run tftp_restore_system ; setexpr cnt $cnt + 1 ; sleep 3 ; done ; setenv cnt
+tftp_update_bl2=tftpboot $loadaddr $file_bl2 && run confirm_continue && mtd erase bl2 && mtd write bl2 $loadaddr 0 $filesize && run nor_verify_bl2
+tftp_update_fip=tftpboot $loadaddr $file_fip && run confirm_continue && mtd erase fip && mtd write fip $loadaddr 0 $filesize && run nor_verify_fip
-- 
