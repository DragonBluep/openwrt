From 32857ec4b0f3d159003d0acfaad60cc8e88f9c79 Mon Sep 17 00:00:00 2001
From: Shiji Yang <yangshiji66@outlook.com>
Date: Sun, 9 Nov 2025 12:01:30 +0800
Subject: [PATCH 2/2] arm: mediatek: add support for AiroPi AX3 (prototype)

Signed-off-by: Shiji Yang <yangshiji66@outlook.com>
---
 arch/arm/dts/mt7981_airopi_ax3.dts  | 395 ++++++++++++++++++++++++++++
 configs/mt7981_airopi_ax3_defconfig | 131 +++++++++
 defenvs/airopi_ax3.env              |  41 +++
 3 files changed, 567 insertions(+)
 create mode 100644 arch/arm/dts/mt7981_airopi_ax3.dts
 create mode 100644 configs/mt7981_airopi_ax3_defconfig
 create mode 100644 defenvs/airopi_ax3.env

diff --git a/arch/arm/dts/mt7981_airopi_ax3.dts b/arch/arm/dts/mt7981_airopi_ax3.dts
new file mode 100644
index 00000000000..4621bb550e6
--- /dev/null
+++ b/arch/arm/dts/mt7981_airopi_ax3.dts
@@ -0,0 +1,395 @@
+// SPDX-License-Identifier: GPL-2.0-or-later OR MIT
+
+/dts-v1/;
+
+#include <dt-bindings/gpio/gpio.h>
+#include <dt-bindings/input/input.h>
+#include <dt-bindings/leds/common.h>
+#include <dt-bindings/pinctrl/mt65xx.h>
+
+#include "mt7981.dtsi"
+
+/ {
+	compatible = "airopi,ax3", "mediatek,mt7981";
+	model = "AiroPi AX3";
+
+	aliases {
+		serial0 = &uart0;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+		tick-timer = &timer0;
+	};
+
+	config {
+		boot-btn1 = "reset";
+		boot-led1 = "blue:status";
+		bootcmd_1-1 = "tftp_load_initramfs_loop";
+		bootcmd_1-2 = "tftp_restore_system_loop";
+		bootcmd_1-3 = "switch_console";
+		bootcmd_1-4 = "env reset";
+	};
+
+	gpio-keys {
+		compatible = "gpio-keys";
+		pinctrl-0 = <&keys_pins>;
+		pinctrl-names = "default";
+
+		button-reset {
+			label = "reset";
+			linux,code = <KEY_RESTART>;
+			gpios = <&pio 1 GPIO_ACTIVE_LOW>;
+		};
+	};
+
+	gpio-leds {
+		compatible = "gpio-leds";
+		pinctrl-0 = <&leds_pins>;
+		pinctrl-names = "default";
+
+		led-status {
+			color = <LED_COLOR_ID_BLUE>;
+			function = LED_FUNCTION_STATUS;
+			gpios = <&pio 9 GPIO_ACTIVE_LOW>;
+			default-state = "on";
+		};
+
+		led-wlan0 {
+			color = <LED_COLOR_ID_BLUE>;
+			function = LED_FUNCTION_WLAN_2GHZ;
+			gpios = <&pio 34 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+
+		led-wlan1 {
+			color = <LED_COLOR_ID_BLUE>;
+			function = LED_FUNCTION_WLAN_5GHZ;
+			gpios = <&pio 35 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+	};
+
+	memory@40000000 {
+		reg = <0x40000000 0x40000000>;
+		device_type = "memory";
+	};
+
+	regulator-fan {
+		compatible = "regulator-fixed";
+		enable-active-high;
+		gpios = <&pio 5 GPIO_ACTIVE_HIGH>;
+		pinctrl-0 = <&fan_power_pins>;
+		pinctrl-names = "default";
+		regulator-boot-on;
+		regulator-max-microvolt = <5000000>;
+		regulator-min-microvolt = <5000000>;
+		regulator-name = "fan_power";
+	};
+
+	reg_vbus: regulator-vbus {
+		compatible = "regulator-fixed";
+		/*
+		 * broken, wrong voltage, invert polarity to disable it
+		 * enable-active-high;
+		 * gpios = <&pio 14 GPIO_ACTIVE_HIGH>;
+		 */
+		gpios = <&pio 14 GPIO_ACTIVE_LOW>;
+		pinctrl-0 = <&usb_vbus_pins>;
+		pinctrl-names = "default";
+		regulator-boot-on;
+		regulator-max-microvolt = <5000000>;
+		regulator-min-microvolt = <5000000>;
+		regulator-name = "usb_vbus";
+	};
+
+	reg_vmmc: regulator-vmmc {
+		compatible = "regulator-fixed";
+		regulator-always-on;
+		regulator-max-microvolt = <3300000>;
+		regulator-min-microvolt = <3300000>;
+		regulator-name = "mmc_power";
+	};
+
+	reg_vqmmc: regulator-vqmmc {
+		compatible = "regulator-fixed";
+		regulator-always-on;
+		regulator-max-microvolt = <3300000>;
+		regulator-min-microvolt = <3300000>;
+		regulator-name = "mmc_io";
+	};
+
+	reserved-memory {
+		#address-cells = <1>;
+		#size-cells = <1>;
+		ranges;
+
+		ramoops@42ff0000 {
+			compatible = "ramoops";
+			reg = <0x42ff0000 0x00010000>;
+			record-size = <0x1000>;
+		};
+
+		secmon@43000000 {
+			reg = <0x43000000 0x00030000>;
+			no-map;
+		};
+	};
+};
+
+&eth {
+	status = "okay";
+	mediatek,gmac-id = <1>;
+	phy-mode = "gmii";
+	phy-handle = <&ethphy0>;
+	pinctrl-0 = <&ephy_2p5g_pins>, <&gbe_leds_pins>, <&mdio_pins>;
+	pinctrl-names = "default";
+
+	ethphy0: ethernet-phy@0 {
+		compatible = "ethernet-phy-ieee802.3-c22";
+		reg = <0>;
+		phy-mode = "gmii";
+	};
+};
+
+&mmc0 {
+	status = "okay";
+	assigned-clock-parents = <&topckgen CLK_TOP_CB_NET2_D4>,
+				 <&topckgen CLK_TOP_CB_NET2_D2>;
+	bus-width = <4>;
+	max-frequency = <50000000>;
+	r_smpl = <0>;
+	broken-cd;
+	cap-sd-highspeed;
+	no-1-8-v;
+	pinctrl-names = "default";
+	pinctrl-0 = <&mmc0_pins>;
+	vmmc-supply = <&reg_vmmc>;
+	vqmmc-supply = <&reg_vqmmc>;
+};
+
+&pio {
+	ephy_2p5g_pins: ephy-2p5g-pins {
+		conf-int {
+			bias-disable;
+			drive-strength = <MTK_DRIVE_2mA>;
+			input-schmitt-enable;
+			pins = "GBE_INT";
+		};
+
+		conf-rst {
+			bias-disable;
+			drive-strength = <MTK_DRIVE_4mA>;
+			pins = "GBE_RESET";
+		};
+	};
+
+	fan_power_pins: fan-power-pins {
+		conf {
+			bias-disable;
+			drive-strength = <MTK_DRIVE_8mA>;
+			pins = "JTAG_JTDI";
+		};
+	};
+
+	fan_tach_pins: fan-tach-pins {
+		conf {
+			bias-pull-up = <MTK_PUPD_SET_R1R0_11>;
+			drive-strength = <MTK_DRIVE_2mA>;
+			input-schmitt-enable;
+			pins = "JTAG_JTMS";
+		};
+	};
+
+	gbe_leds_pins: gbe-leds-pins {
+		mux {
+			function = "led";
+			groups = "gbe_led0", "gbe_led1";
+		};
+
+		conf {
+			bias-disable;
+			drive-strength = <MTK_DRIVE_4mA>;
+			pins = "JTAG_JTRST_N", "WO_JTAG_JTRST_N";
+		};
+	};
+
+	keys_pins: keys-pins {
+		conf {
+			bias-disable;
+			drive-strength = <MTK_DRIVE_2mA>;
+			input-schmitt-enable;
+			pins = "GPIO_RESET";
+		};
+	};
+
+	leds_pins: leds-pins {
+		conf {
+			bias-disable;
+			drive-strength = <MTK_DRIVE_4mA>;
+			pins = "WO_JTAG_JTDO", "PCIE_CLK_REQ", "PCIE_WAKE_N";
+		};
+	};
+
+	mdio_pins: mdc-mdio-pins {
+		mux {
+			function = "eth";
+			groups = "smi_mdc_mdio";
+		};
+
+		conf-clk {
+			bias-pull-down = <MTK_PUPD_SET_R1R0_10>;
+			drive-strength = <MTK_DRIVE_4mA>;
+			pins = "SMI_MDC";
+		};
+
+		conf-io {
+			bias-disable;
+			drive-strength = <MTK_DRIVE_4mA>;
+			input-schmitt-disable;
+			pins = "SMI_MDIO";
+		};
+	};
+
+	mmc0_pins: mmc0-pins {
+		mux {
+			function = "flash";
+			groups = "emmc_4";
+		};
+
+		conf-cmd-dat {
+			bias-pull-up = <MTK_PUPD_SET_R1R0_01>;
+			drive-strength = <MTK_DRIVE_4mA>;
+			input-enable;
+			input-schmitt-disable;
+			pins = "SPI0_CLK", "SPI0_MOSI", "SPI0_MISO",
+			       "SPI0_CS", "SPI1_MISO";
+		};
+
+		conf-clk {
+			bias-pull-down = <MTK_PUPD_SET_R1R0_10>;
+			drive-strength = <MTK_DRIVE_8mA>;
+			pins = "SPI1_CS";
+		};
+	};
+
+	pwm2_pins: pwm2-pins {
+		mux {
+			function = "pwm";
+			groups = "pwm2";
+		};
+
+		conf {
+			bias-disable;
+			drive-strength = <MTK_DRIVE_8mA>;
+			pins = "JTAG_JTCLK";
+		};
+	};
+
+	spi2_pins: spi2-pins {
+		mux {
+			function = "spi";
+			groups = "spi2", "spi2_wp_hold";
+		};
+
+		conf {
+			bias-disable;
+			input-schmitt-disable;
+			drive-strength = <MTK_DRIVE_4mA>;
+			pins = "SPI2_CS", "SPI2_HOLD", "SPI2_WP",
+			       "SPI2_CLK", "SPI2_MOSI", "SPI2_MISO";
+		};
+	};
+
+	uart0_pins: uart0-pins {
+		mux {
+			function = "uart";
+			groups = "uart0";
+		};
+
+		conf {
+			bias-disable;
+			input-schmitt-disable;
+			drive-strength = <MTK_DRIVE_4mA>;
+			pins = "UART0_RXD", "UART0_TXD";
+		};
+	};
+
+	usb_vbus_pins: usb-vbus-pins {
+		conf {
+			bias-disable;
+			drive-strength = <MTK_DRIVE_8mA>;
+			pins = "USB_VBUS";
+		};
+	};
+};
+
+&pwm {
+	status = "okay";
+	pinctrl-names = "default";
+	pinctrl-0 = <&fan_tach_pins>, <&pwm2_pins>;
+};
+
+&spi2 {
+	status = "okay";
+	#address-cells = <1>;
+	#size-cells = <0>;
+	enhance_timing;
+	dma_ext;
+	ipm_design;
+	support_quad;
+	sample_sel = <0>;
+	tick_dly = <2>;
+	pinctrl-0 = <&spi2_pins>;
+	pinctrl-names = "default";
+
+	flash@0 {
+		compatible = "jedec,spi-nor";
+		reg = <0>;
+		m25p,fast-read;
+		spi-max-frequency = <52000000>;
+		spi-rx-bus-width = <4>;
+		spi-tx-bus-width = <4>;
+
+		partitions {
+			compatible = "fixed-partitions";
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			partition@0 {
+				label = "bl2";
+				reg = <0x000000 0x040000>;
+			};
+
+			partition@40000 {
+				label = "u-boot-env";
+				reg = <0x040000 0x010000>;
+			};
+
+			partition@50000 {
+				label = "factory";
+				reg = <0x050000 0x0b0000>;
+			};
+
+			partition@100000 {
+				label = "fip";
+				reg = <0x100000 0x080000>;
+			};
+
+			partition@180000 {
+				label = "firmware";
+				reg = <0x180000 0xe80000>;
+			};
+		};
+	};
+};
+
+&uart0 {
+	status = "okay";
+	pinctrl-0 = <&uart0_pins>;
+	pinctrl-names = "default";
+};
+
+&xhci {
+	vbus-supply = <&reg_vbus>;
+};
